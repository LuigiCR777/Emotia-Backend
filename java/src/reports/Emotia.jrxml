<jasperReport name="Emotia" language="java" pageWidth="595" pageHeight="842" columnWidth="555" leftMargin="20" rightMargin="20" topMargin="20" bottomMargin="20" uuid="0d5ae0cd-877f-4afb-9232-94e786b54136">
	<property name="com.jaspersoft.studio.data.sql.tables" value=""/>
