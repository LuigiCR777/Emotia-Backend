	<style name="titulo" forecolor="#0E5A8A"/>
	<style name="texto_secundario" mode="Opaque" forecolor="#4A4443"/>
	<parameter name="User" class="java.lang.Integer"/>
	<parameter name="phq" class="java.lang.String">
		<defaultValueExpression><![CDATA["PHQ-9"]]></defaultValueExpression>
	</parameter>
	<parameter name="gad" class="java.lang.String">
		<defaultValueExpression><![CDATA["GAD-7"]]></defaultValueExpression>
	</parameter>
	<parameter name="dass" class="java.lang.String">
		<defaultValueExpression><![CDATA["DASS-21"]]></defaultValueExpression>
	</parameter>
	<parameter name="Logo" class="java.io.InputStream"/>
	<query language="SQL"><![CDATA[WITH ultimos_test AS (
    SELECT
        a.id_usuario,
        a.nombre || ' ' || COALESCE(a.apellido, '') AS nombre,
        b.id_test,
        b.tipo_test,
        b.fecha_test,
        e.puntaje,
        e.nivel_riesgo,

        ROW_NUMBER() OVER (
            PARTITION BY b.tipo_test
            ORDER BY b.fecha_test DESC, b.id_test DESC
        ) AS fila

    FROM usuarios a

    INNER JOIN tests_emocionales b
        ON b.id_usuario = a.id_usuario

    INNER JOIN resultados e
        ON e.id_test = b.id_test

    WHERE a.id_usuario = $P{User}
),

emociones AS (
    SELECT
        b.id_test,
        MAX(d.emocion_detectada) AS emocion_detectada
    FROM tests_emocionales b

    INNER JOIN respuestas_test c
        ON c.id_test = b.id_test

    INNER JOIN analitica_ia_test d
        ON d.id_respuesta = c.id_respuesta

    WHERE d.emocion_detectada <> 'No detectado'

    GROUP BY b.id_test
),

datos AS (
    SELECT
        u.*,
        em.emocion_detectada
    FROM ultimos_test u

    LEFT JOIN emociones em
        ON em.id_test = u.id_test

    WHERE u.fila = 1
)

SELECT
    MAX(nombre) AS nombre,
    id_usuario,

    MAX(CASE
        WHEN tipo_test = 'PHQ-9'
        THEN puntaje
    END) AS puntaje_phq,

    MAX(CASE
        WHEN tipo_test = 'PHQ-9'
        THEN nivel_riesgo
    END) AS riesgo_phq,

    MAX(CASE
        WHEN tipo_test = 'PHQ-9'
        THEN emocion_detectada
    END) AS emocion_phq,

    MAX(CASE
        WHEN tipo_test = 'GAD-7'
        THEN puntaje
    END) AS puntaje_gad,

    MAX(CASE
        WHEN tipo_test = 'GAD-7'
        THEN nivel_riesgo
    END) AS riesgo_gad,

    MAX(CASE
        WHEN tipo_test = 'GAD-7'
        THEN emocion_detectada
    END) AS emocion_gad,

    MAX(CASE
        WHEN tipo_test = 'DASS-21'
        THEN puntaje
    END) AS puntaje_dass,

    MAX(CASE
        WHEN tipo_test = 'DASS-21'
        THEN nivel_riesgo
    END) AS riesgo_dass,

    MAX(CASE
        WHEN tipo_test = 'DASS-21'
        THEN emocion_detectada
    END) AS emocion_dass

FROM datos
GROUP BY id_usuario;]]></query>
